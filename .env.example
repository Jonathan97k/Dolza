APP_NAME=DolzaRealEstate
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://yourdomain.com

LOG_CHANNEL=stack
LOG_LEVEL=warning

# Database — use sqlite for dev, mysql for production
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dolza_real_estate
DB_USERNAME=root
DB_PASSWORD=

# For SQLite (dev), comment out mysql above and uncomment:
# DB_CONNECTION=sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_DOMAIN=

SANCTUM_STATEFUL_DOMAINS=yourdomain.com

FILESYSTEM_DISK=local
