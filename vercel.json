{
  "version": 2,
  "framework": null,
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0",
      "memory": 3008,
      "maxDuration": 60
    }
  },
  "outputDirectory": "public",
  "routes": [
    {
      "src": "/(css/.*)",
      "dest": "/public/$1"
    },
    {
      "src": "/(js/.*)",
      "dest": "/public/$1"
    },
    {
      "src": "/(images/.*)",
      "dest": "/public/$1"
    },
    {
      "src": "/(favicon\\.ico|favicon\\.png|manifest\\.json|sw\\.js|offline\\.html)",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "env": {
    "APP_CONFIG_CACHE": "/tmp/config.php",
    "APP_EVENTS_CACHE": "/tmp/events.php",
    "APP_PACKAGES_CACHE": "/tmp/packages.php",
    "APP_ROUTES_CACHE": "/tmp/routes.php",
    "APP_SERVICES_CACHE": "/tmp/services.php",
    "VIEW_COMPILED_PATH": "/tmp",
    "CACHE_DRIVER": "array",
    "LOG_CHANNEL": "stderr",
    "SESSION_DRIVER": "array"
  }
}
