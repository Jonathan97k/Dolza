# PostgreSQL connection string (Neon, Supabase, or local)
# Example: "postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/dolza?sslmode=require"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dolza"

NEXTAUTH_SECRET="change-this-to-a-random-string"
NEXTAUTH_URL="http://localhost:3000"

